# лЈЁнҠё нҷҳкІҪліҖмҲҳ (docker-composeмҡ©)
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=dataset_pipeline

# в”Җв”Җ CORS в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# нҢҖмӣҗмқҙ м ‘мҶҚн•  м„ңлІ„ IPлҘј м¶”к°Җн•ҳм„ёмҡ”.
# мҳҲ) CORS_ORIGINS=http://192.168.1.100:8080,http://192.168.1.200:8080
CORS_ORIGINS_RAW=http://localhost:8080

# в”Җв”Җ NAS / кіөмң  мҠӨнҶ лҰ¬м§Җ кІҪлЎң в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# NASк°Җ м„ңлІ„ PCм—җ л§ҲмҡҙнҠёлҗҳм–ҙ мһҲлҠ” кІҪмҡ° м•„лһҳ кІҪлЎңлҘј м„Өм •н•ҳм„ёмҡ”.
# лҜём„Өм • мӢң м„ңлІ„ лЎңм»¬ л””мҠӨнҒ¬ (./data/uploads, ./data/exports) м—җ м ҖмһҘлҗ©лӢҲлӢӨ.
#
# мҳҲмӢң (NASк°Җ /mnt/nas/dataset_pipeline м—җ л§ҲмҡҙнҠёлҗң кІҪмҡ°):
#   UPLOADS_HOST_PATH=/mnt/nas/dataset_pipeline/uploads
#   EXPORTS_HOST_PATH=/mnt/nas/dataset_pipeline/exports
#
# мҳҲмӢң (Windows м„ңлІ„, NASк°Җ Z:\dataset_pipeline мңјлЎң л§ҲмҡҙнҠёлҗң кІҪмҡ°):
#   UPLOADS_HOST_PATH=Z:\dataset_pipeline\uploads
#   EXPORTS_HOST_PATH=Z:\dataset_pipeline\exports
UPLOADS_HOST_PATH=../../../../mnt/data/uploads
EXPORTS_HOST_PATH=../../../../mnt/data/exports