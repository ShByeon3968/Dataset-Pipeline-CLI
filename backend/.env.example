# ════════════════════════════════════════════════════════════════════════
#  Dataset Pipeline — 백엔드 환경변수 예시
#  이 파일을 복사해서 .env 로 저장하고, 값을 수정하세요.
#  cp .env.example .env
# ════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=dataset_pipeline

# ── CORS ─────────────────────────────────────────────────────────────
# 팀원들이 각자 PC에서 서버에 접속하는 경우, 서버 IP를 추가하세요.
#
# 예시 (서버 IP: 192.168.1.100):
#   CORS_ORIGINS=http://192.168.1.100:8080,http://localhost:8080
#
# 쉼표 구분 또는 JSON 배열 형식 모두 지원합니다.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080,http://localhost

# ── Roboflow (선택) ────────────────────────────────────────────────────
# Roboflow에서 데이터셋을 가져올 때 사용합니다.
ROBOFLOW_API_KEY=

# ── 임베딩 모델 (선택) ────────────────────────────────────────────────
# "resnet50" 또는 "clip"
EMBEDDING_MODEL=resnet50

# ── Debug ─────────────────────────────────────────────────────────────
DEBUG=false
